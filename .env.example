# OpenAI Configuration
OPENAI_API_KEY=sk-...

# Anthropic Configuration (optional)
ANTHROPIC_API_KEY=sk-ant-...

# Google Earth Engine
GEE_PROJECT_ID=your-project-id
GEE_SERVICE_ACCOUNT_PATH=./config/gee-key.json
GEE_SERVICE_ACCOUNT_EMAIL=service-account@your-project.iam.gserviceaccount.com

# Sentinel-2
SENTINEL_USERNAME=your-copernicus-username
SENTINEL_PASSWORD=your-copernicus-password
SENTINEL_API_URL=https://scihub.copernicus.eu/dhus
SENTINEL_DOWNLOAD_DIR=./data/sentinel

# Hyperspectral (optional)
HYPERSPECTRAL_DATA_DIR=./data/hyperspectral
HYPERSPECTRAL_API_TOKEN=your-hyperspectral-provider-token

# Copernicus Atmosphere Monitoring Service (CAMS) / CDS API
CAMS_API_URL=https://ads.atmosphere.copernicus.eu/api/v2
CAMS_API_KEY=12345:your-cds-api-key

# GBIF
GBIF_USER_AGENT=climate-intelligence-copilot/1.0

# Optional EDGAR dataset path
EDGAR_CSV_PATH=./data/external/edgar_country_totals.csv

# Database
DATABASE_URL=sqlite:///./data/climate_copilot.db

# Application
DEBUG=False
LOG_LEVEL=INFO
